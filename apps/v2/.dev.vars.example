# Copy to .dev.vars for local `wrangler dev`.
AUTH_DEV_BYPASS = "true"
#
# Production wrangler.toml must NOT set AUTH_DEV_BYPASS.
# ACCESS_TEAM_DOMAIN = "your-team-name"
# ACCESS_AUD = "..."  # recommended
# Method B: ACCESS_ALLOWED_EMAIL_DOMAIN = "example.com"
# Method A: ACCESS_ALLOWED_EMAILS = "alice@example.com,bob@example.com"
#
# Local dev: optional X-Qarows-User request header, or defaults to dev@local.
