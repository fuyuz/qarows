# Copy to .dev.vars for local `wrangler dev`.
#
# Disable Access enforcement locally (Vite proxy does not send Access headers).
ACCESS_REQUIRED = "false"
#
# Optional: simulate a signed-in user in local dev
# X-Qarows-User is read from the HTTP request header, not from here.
#
# Production uses Cloudflare Access (Cf-Access-Authenticated-User-Email).
# Set ACCESS_REQUIRED = "true" in wrangler.toml [vars] for deploy.
