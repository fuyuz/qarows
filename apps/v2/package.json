{
  "name": "@qarows/v2",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "dev:worker": "wrangler dev --config wrangler.toml",
    "db:migrate:local": "wrangler d1 migrations apply qarows-v2 --local --config wrangler.toml",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.worker.json",
    "deploy": "wrangler deploy --config wrangler.toml"
  },
  "dependencies": {
    "@qarows/shared": "*",
    "@qarows/ui": "*",
    "hono": "^4.12.27",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20250628.0",
    "@tailwindcss/vite": "^4.3.1",
    "@types/node": "^22.15.29",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.5.2",
    "tailwindcss": "^4.3.1",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.8.3",
    "vite": "^6.3.5",
    "wrangler": "^4.22.0"
  }
}
