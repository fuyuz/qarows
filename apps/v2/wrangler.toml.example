# https://developers.cloudflare.com/workers/wrangler/configuration/
name = "qarows-v2"
main = "worker/index.ts"
compatibility_date = "2026-06-28"
compatibility_flags = ["nodejs_compat"]

# Copy to wrangler.toml and fill in before deploy:
# account_id = "YOUR_ACCOUNT_ID"

[observability]
enabled = true

[observability.logs]
head_sampling_rate = 1

[observability.traces]
enabled = true
head_sampling_rate = 0.01

[vars]
# Access JWT is always enforced (cannot be disabled in production).
# Zero Trust team name (https://<ACCESS_TEAM_DOMAIN>.cloudflareaccess.com)
ACCESS_TEAM_DOMAIN = "your-team-name"
# Access Application AUD tag — copy from Zero Trust → Access → Application → Overview
# See docs/deploy-v2.md §4.4 (not auto-injected by Cloudflare)
ACCESS_AUD = "xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
#
# Worker-side allow guard (choose Method A or B in Access policy + mirror here):
# Method B — organization domain:
# ACCESS_ALLOWED_EMAIL_DOMAIN = "example.com"
# Method A — named individuals (comma-separated):
# ACCESS_ALLOWED_EMAILS = "alice@example.com,bob@example.com"

[assets]
directory = "./dist"
not_found_handling = "single-page-application"
binding = "ASSETS"

[[d1_databases]]
binding = "DB"
database_name = "qarows-v2"
# After `wrangler d1 create qarows-v2`, set:
# database_id = "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
migrations_dir = "migrations"

[durable_objects]
bindings = [{ name = "PROJECT", class_name = "ProjectRoom" }]

[[migrations]]
tag = "v1"
new_sqlite_classes = ["ProjectRoom"]
